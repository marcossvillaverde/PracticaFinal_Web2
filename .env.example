# Servidor
PORT=3000
NODE_ENV=development
PUBLIC_URL=http://localhost:3000

# Base de datos MongoDB Atlas
DB_URI=mongodb+srv://<usuario>:<password>@cluster0.xxxxx.mongodb.net/bildyapp?appName=Cluster0

# JWT — genera el secret con: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
JWT_SECRET=cadena_aleatoria_de_al_menos_32_caracteres
JWT_ACCESS_EXPIRES=15m
JWT_REFRESH_EXPIRES=7d

# Cloudinary — subida de firmas y PDFs
CLOUDINARY_CLOUD_NAME=tu_cloud_name
CLOUDINARY_API_KEY=tu_api_key
CLOUDINARY_API_SECRET=tu_api_secret

# Nodemailer — envío de emails
MAIL_HOST=smtp.gmail.com
MAIL_PORT=587
MAIL_USER=tu_email@gmail.com
MAIL_PASS=tu_app_password

# Slack — logging de errores 5XX
SLACK_WEBHOOK_URL=https://hooks.slack.com/services/xxx/yyy/zzz